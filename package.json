{
  "name": "digi-now",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "scriptsDescriptions": {
    "start": "Start the Expo development server",
    "android": "Start Expo for Android development",
    "ios": "Start Expo for iOS development",
    "web": "Start Expo for web development",
    "lint": "Check code for linting issues using Biome",
    "lint:fix": "Auto-fix linting issues using Biome",
    "format": "Format code using Biome",
    "format:check": "Check code formatting without making changes",
    "check": "Run both linting and formatting checks",
    "check:fix": "Auto-fix all linting and formatting issues"
  },
  "dependencies": {
    "expo": "~55.0.5",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
